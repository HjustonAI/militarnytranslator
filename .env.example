# Militaria Translation Studio — zmienne środowiskowe
#
# Aplikacja działa bez żadnej konfiguracji — domyślnie uruchamia się
# w trybie demo (lokalne, deterministyczne odpowiedzi, bez klucza API).
#
# Aby włączyć tryb API z realnym modelem, skopiuj ten plik jako .env.local
# i uzupełnij klucz API.

# --- Tryb API (opcjonalny) ---

# Klucz API modelu. Bez niego aplikacja pozostaje w trybie demo.
ANTHROPIC_API_KEY=

# Nazwa modelu (opcjonalnie; pominięcie = model domyślny).
# LLM_MODEL=

# Wymuszenie trybu demo nawet przy obecnym kluczu API (ustaw na 1).
# MOCK_MODE=
